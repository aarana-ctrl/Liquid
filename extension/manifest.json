{
  "manifest_version": 3,
  "name": "Liquid — MyPlan Sync",
  "version": "1.7.0",
  "description": "Automatically imports your UW DARS degree audits into Liquid — every program you run through DARS is captured for exact, per-category Compare. No copy/paste.",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": [
    "https://myplan.uw.edu/*",
    "https://liquid-planner-api.onrender.com/*",
    "https://*.onrender.com/*",
    "https://*.vercel.app/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html", "default_title": "Liquid Planner Sync", "default_icon": { "16": "icon16.png", "48": "icon48.png", "128": "icon128.png" } },
  "icons": { "16": "icon16.png", "48": "icon48.png", "128": "icon128.png" },
  "content_scripts": [
    { "matches": ["https://myplan.uw.edu/audit*"], "js": ["content-dars.js"], "run_at": "document_idle" },
    { "matches": ["https://*.vercel.app/*", "http://localhost/*"], "js": ["content-app.js"], "run_at": "document_idle" }
  ]
}
