# Copy to .env and fill in for production. The server runs without these in dev
# mode (it accepts the /api/auth/dev demo login used by the prototype UI).

PORT=8787

# Secret used to sign the app's own session JWTs. Use a long random string.
APP_JWT_SECRET=change-me-to-a-long-random-string

# Google OAuth — the Web/iOS OAuth client ID(s). Comma-separate if more than one.
# Used as the expected audience when verifying Google ID tokens.
GOOGLE_CLIENT_ID=

# Apple Sign in — your Services ID / bundle ID (the token audience).
APPLE_CLIENT_ID=

# Allowed CORS origins (comma-separated). Defaults to * in dev.
CORS_ORIGINS=

# Where to send the user after a successful UW NetID (OIDC) login.
WEB_ORIGIN=http://localhost:5173

# ---- UW NetID SSO via OIDC (Entra ID / Microsoft) ----
# Register an app in UW's Entra (Azure AD) tenant to get these. When set, the
# NetID button does a real redirect → UW WebLogin → 2FA → back, signed in.
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=
OIDC_SCOPES=openid profile email

# ---- Database ----
# DB=firestore switches from the JSON file store to Firestore.
DB=
FIRESTORE_PROJECT_ID=
# Provide the service-account key ONE of these ways:
#  (a) local dev: absolute path to the downloaded key file
GOOGLE_APPLICATION_CREDENTIALS=
#  (b) hosting: paste the whole key JSON as a single-line secret (overrides (a))
FIREBASE_SERVICE_ACCOUNT=
